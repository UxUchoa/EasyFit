# Supabase Transaction Pooler (porta 6543): usado pela aplicacao serverless.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"

# Supabase Session Pooler (porta 5432): usado pelo Prisma Migrate.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# Deve ter pelo menos 32 caracteres aleatorios em cada ambiente.
SESSION_SECRET="replace-with-at-least-32-random-characters"

# Expiração absoluta e rotação periódica do token de sessão.
SESSION_TTL_DAYS="30"
SESSION_ROTATION_HOURS="24"

# Origem canonica usada em validacoes de seguranca e links internos.
APP_URL="http://localhost:3000"

# Origens adicionais separadas por vírgula, por exemplo URLs de Preview autorizadas.
ALLOWED_ORIGINS=""

# Prazo de disponibilidade do arquivo de exportação autenticado.
EXPORT_TTL_HOURS="24"

# Prazo operacional de retenção de protocolos; validar com assessoria jurídica antes da produção.
SUBJECT_REQUEST_RETENTION_DAYS="365"

# Resiliência e quota lógica do Open Food Facts; ajuste aos termos homologados do fornecedor.
OPEN_FOOD_FACTS_TIMEOUT_MS="5000"
OPEN_FOOD_FACTS_MAX_ATTEMPTS="3"
OPEN_FOOD_FACTS_RETRY_BASE_MS="150"
OPEN_FOOD_FACTS_CIRCUIT_FAILURES="4"
OPEN_FOOD_FACTS_CIRCUIT_RESET_MS="60000"
OPEN_FOOD_FACTS_QUOTA_PER_MINUTE="60"

# Identificação solicitada pelo Open Food Facts. Em produção, informe uma URL ou e-mail de contato.
OPEN_FOOD_FACTS_CONTACT="http://localhost:3000"

# A busca textual pública permite no máximo 10 requisições por minuto/IP.
OPEN_FOOD_FACTS_SEARCH_TIMEOUT_MS="7000"
OPEN_FOOD_FACTS_SEARCH_MAX_ATTEMPTS="2"
OPEN_FOOD_FACTS_SEARCH_RETRY_BASE_MS="200"
OPEN_FOOD_FACTS_SEARCH_CIRCUIT_FAILURES="4"
OPEN_FOOD_FACTS_SEARCH_CIRCUIT_RESET_MS="60000"
OPEN_FOOD_FACTS_SEARCH_QUOTA_PER_MINUTE="10"
